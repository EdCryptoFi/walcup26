# Walrus Memory — get credentials at https://memory.walrus.xyz
MEMWAL_PRIVATE_KEY=your_ed25519_hex_key_here
MEMWAL_ACCOUNT_ID=your_walrus_account_object_id_here
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz

# Groq — get at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Convex — get at https://dashboard.convex.dev (your project deployment URL)
CONVEX_URL=https://your-deployment.convex.cloud

# Admin — any random hex string (protects admin API routes)
ADMIN_SECRET=your_random_hex_secret_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "true" to skip real MemWal calls for seeded/demo users
NEXT_PUBLIC_DEMO_MODE=false
