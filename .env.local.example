# Walrus Memory — get credentials at https://memory.walrus.xyz
MEMWAL_PRIVATE_KEY=your_ed25519_hex_key_here
MEMWAL_ACCOUNT_ID=your_walrus_account_object_id_here
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz

# Anthropic — get at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "true" to use demo mode (no real MemWal calls for seeded users)
NEXT_PUBLIC_DEMO_MODE=false
